#!/bin/sh
# Strip Claude Code session IDs / footers from commit messages.
msg_file="$1"
[ -f "$msg_file" ] || exit 0
tmp="$(mktemp)"
sed -E '/claude\.ai\/code\/session/d; /Generated (with|by).*Claude Code/d; /Co-[Aa]uthored-[Bb]y:.*[Cc]laude/d' "$msg_file" | git stripspace > "$tmp"
mv "$tmp" "$msg_file"
